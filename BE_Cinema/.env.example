PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=Cinema_local

# Prisma connection string
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/Cinema_local?schema=public"

# JWT secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here
